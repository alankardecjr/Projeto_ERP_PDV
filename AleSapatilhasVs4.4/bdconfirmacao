    with conectar() as conn:
        conn.execute("INSERT INTO cliente_interacoes (cliente_id, tipo_contato, assunto, detalhes, vendedor_responsavel) VALUES (?,?,?,?,?)",
                     (cliente_id, tipo, assunto, detalhes, vendedor))

# --- FUNÇÕES DE VENDAS E RECEITAS ---

def realizar_venda(cliente_id, lista_produtos, forma_pgto, parcelas=1, desconto_total=0):
    with conectar() as conn:
        cursor = conn.cursor()
        try:
            # Validação Estoque
            for p in lista_produtos:
                qtd_atual = cursor.execute("SELECT quantidade FROM produtos WHERE id=?", (p['id'],)).fetchone()[0]
                if qtd_atual < p['qtd']: return False, f"Estoque baixo: {p['id']}"

            total_bruto = sum(p['qtd'] * p['preco'] for p in lista_produtos)
            total_liquido = total_bruto - desconto_total
            
            cursor.execute("INSERT INTO vendas (cliente_id, valor_bruto, desconto, valor_total, forma_pagamento, qtd_parcelas) VALUES (?,?,?,?,?,?)",
                           (cliente_id, total_bruto, desconto_total, total_liquido, forma_pgto, parcelas))
            venda_id = cursor.lastrowid

            for p in lista_produtos:
                cursor.execute("UPDATE produtos SET quantidade = quantidade - ? WHERE id=?", (p['qtd'], p['id']))
                cursor.execute("INSERT INTO itens_venda (venda_id, produto_id, quantidade, preco_unitario, subtotal) VALUES (?,?,?,?,?)",
                               (venda_id, p['id'], p['qtd'], p['preco'], p['qtd']*p['preco']))

            # Geração de Receitas (Parcelas)
            valor_parcela = round(total_liquido / parcelas, 2)
            for i in range(parcelas):
                venc = adicionar_meses(datetime.now(), i).strftime("%Y-%m-%d")
                cursor.execute("""INSERT INTO receitas (venda_id, cliente_id, descricao, valor_base, data_vencimento, parcela_atual, total_parcelas) 
                                  VALUES (?,?,?,?,?,?,?)""", (venda_id, cliente_id, f"Venda #{venda_id}", valor_parcela, venc, i+1, parcelas))
            
            conn.commit()
            return True, "Venda concluída!"
        except Exception as e:
            conn.rollback()
            return False, str(e)

# --- FUNÇÕES DE DESPESAS E RECORRÊNCIA ---

def cadastrar_despesa(fornecedor, descricao, categoria, valor, recorrencia, parcelas, vencimento_inicial):
    """Suporta recorrencias: 'Mensal', 'Trimestral', 'Semestral', 'Anual'."""
    data_ini = datetime.strptime(vencimento_inicial, "%Y-%m-%d")
    meses_salto = {'Mensal': 1, 'Trimestral': 3, 'Semestral': 6, 'Anual': 12, 'Única': 0}
    salto = meses_salto.get(recorrencia, 1)

    with conectar() as conn:
        cursor = conn.cursor()
        for i in range(parcelas):
            venc_atual = adicionar_meses(data_ini, i * salto).strftime("%Y-%m-%d")
            cursor.execute("""INSERT INTO despesas (fornecedor, descricao, categoria, valor_base, data_vencimento, recorrencia, parcela_atual, total_parcelas)
                              VALUES (?,?,?,?,?,?,?,?)""", (fornecedor, descricao, categoria, valor, venc_atual, recorrencia, i+1, parcelas))
        conn.commit()

# --- FUNÇÃO DE BAIXA (O NOVO MÓDULO PAGAMENTO) ---

def registrar_pagamento_baixa(tipo_origem, id_documento, valor_base_pg, forma, conta, t_enc='Valor Fixo', v_enc=0, t_desc='Valor Fixo', v_desc=0, obs=""):
    """Realiza a baixa financeira, calcula encargos e registra no Fluxo de Caixa."""
    val_final, juros, desconto = calcular_valor_com_ajustes(valor_base_pg, t_enc, v_enc, t_desc, v_desc)
    
    with conectar() as conn:
        cursor = conn.cursor()
        if tipo_origem == 'Receita':
            cursor.execute("""INSERT INTO pagamentos (receita_id, valor_pago_final, juros_calculados, descontos_calculados, forma_pagamento, conta_bancaria, observacao)
                              VALUES (?,?,?,?,?,?,?)""", (id_documento, val_final, juros, desconto, forma, conta, obs))
            cursor.execute("UPDATE receitas SET status = 'Pago' WHERE id = ?", (id_documento,))
        else:
            cursor.execute("""INSERT INTO pagamentos (despesa_id, valor_pago_final, juros_calculados, descontos_calculados, forma_pagamento, conta_bancaria, observacao)
                              VALUES (?,?,?,?,?,?,?)""", (id_documento, val_final, juros, desconto, forma, conta, obs))
            cursor.execute("UPDATE despesas SET status = 'Pago' WHERE id = ?", (id_documento,))
        conn.commit()
        return True, val_final

# --- DASHBOARD E RELATÓRIOS ---

def dashboard_resumo():
    with conectar() as conn:
        cursor = conn.cursor()
        hoje = datetime.now().strftime("%Y-%m-%d")
        
        estoque = cursor.execute("SELECT produto, quantidade FROM produtos WHERE quantidade < 3").fetchall()
        a_receber = cursor.execute("SELECT SUM(valor_base) FROM receitas WHERE status='Pendente' AND data_vencimento >= ?", (hoje,)).fetchone()[0]
        atrasado = cursor.execute("SELECT SUM(valor_base) FROM receitas WHERE status='Pendente' AND data_vencimento < ?", (hoje,)).fetchone()[0]
        saldo_caixa = cursor.execute("SELECT SUM(valor_pago_final) FROM pagamentos").fetchone()[0]
        
        return {
            "estoque_baixo": estoque,
            "proximas_receitas": a_receber or 0,
            "inadimplencia": atrasado or 0,
            "saldo_real": saldo_caixa or 0
        }

